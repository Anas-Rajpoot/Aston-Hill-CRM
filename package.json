{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "serve": "php artisan serve --host=127.0.0.1 --port=8000",
        "dev:all": "concurrently --kill-others-on-fail -n \"laravel,vite\" -c \"green,cyan\" \"npm:serve\" \"npm:dev\"",
        "dev:reset": "kill-port 8000 5173 && npm run dev:all"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.3",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "kill-port": "^2.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "datatables.net": "^2.3.6",
        "datatables.net-dt": "^2.3.6",
        "jquery": "^4.0.0",
        "pinia": "^3.0.4",
        "vue": "^3.5.27",
        "vue-router": "^4.6.4",
        "vuedraggable": "^4.1.0"
    }
}
